<div class="reviews-container">

  <!-- TOP SECTION -->
  <div class="reviews-top">

    <!-- LEFT (RATING BLOCK) -->
    <div class="reviews-left">
      <div class="rating-row">
        <span class="rating-number" id="avg-rating">—</span>
        <span class="rating-outof">/5</span>
        <span class="rating-text">Overall Rating</span>
      </div>

      <div class="review-count" id="review-count">Loading reviews…</div>
    </div>

    <!-- RIGHT (CTA BLOCK) -->
    <div class="reviews-right">
      <p class="review-request">Share Your Experience !</p>
      <div class="interactive-stars" id="interactive-stars">
        <!-- SVG stars for half-star support -->
        <span class="star-svg" data-value="1"></span>
        <span class="star-svg" data-value="2"></span>
        <span class="star-svg" data-value="3"></span>
        <span class="star-svg" data-value="4"></span>
        <span class="star-svg" data-value="5"></span>
      </div>

      <!-- Review Modal -->
      <div id="review-modal" class="review-modal" style="display:none;">
        <div class="modal-content">
          <span class="close-modal" id="close-modal">&times;</span>
          <h3>Write a Review</h3>
          <div class="modal-stars" id="modal-stars"></div>
          <textarea id="review-textarea" placeholder="Share your thoughts..." rows="4"></textarea>
          <button class="submit-review-btn">Submit</button>
        </div>
      </div>
    </div>

  </div>

  <!-- REVIEWS -->
  <div class="reviews-list" id="reviews-list">
    <!-- Reviews loaded dynamically from API -->
  </div>

  <style>
    .interactive-stars {
      display: flex;
      gap: 6px;
      font-size: 32px;
      cursor: pointer;
      margin-bottom: 10px;
    }
    .star-svg {
      display: inline-block;
      width: 25px;
      height: 25px;
      vertical-align: middle;
      cursor: pointer;
    }
    .star-svg svg {
      width: 100%;
      height: 100%;
      display: block;
    }

    /* Modal Styles */
    .review-modal {
      display: flex;
      align-items: center;
      justify-content: center;
      position: fixed;
      z-index: 1000;
      left: 0; top: 0; width: 100vw; height: 100vh;
      background: rgba(0,0,0,0.25);
    }
    .modal-content {
      background: #fffbe9;
      padding: 32px 28px 24px 28px;
      border-radius: 10px;
      min-width: 320px;
      box-shadow: 0 2px 16px rgba(0,0,0,0.12);
      position: relative;
      display: flex;
      flex-direction: column;
      align-items: flex-start;
    }
    .close-modal {
      position: absolute;
      top: 12px;
      right: 18px;
      font-size: 22px;
      color: #888;
      cursor: pointer;
    }
    .modal-stars {
      display: flex;
      gap: 6px;
      font-size: 28px;
      margin-bottom: 12px;
    }
    #review-textarea {
      width: 100%;
      border-radius: 6px;
      border: 1px solid #ddd;
      padding: 10px;
      font-size: 15px;
      margin-bottom: 16px;
      resize: vertical;
    }
    .submit-review-btn {
      background: #333;
      color: #fff;
      border: none;
      padding: 10px 22px;
      border-radius: 4px;
      font-size: 15px;
      font-weight: 600;
      cursor: pointer;
    }
    .submit-review-btn:hover {
      background: #000;
    }

    .reviews-container {
      margin-top: 60px;
      font-family: inherit;
      max-width: 1100px;
      margin: auto;
      padding: 25px 30px;
    }

    /* TOP LAYOUT */
    .reviews-top {
      display: flex;
      justify-content: left;
      align-items: left;
      margin-left: 60px;
    }

    /* LEFT */
    .reviews-left {
      padding-right: 30px;
      border-right: 2px solid #333;
    }

    .rating-row {
      display: flex;
      align-items: baseline;
      gap: 8px;
    }

    .rating-number {
      font-size: 48px;
      font-weight: bold;
    }

    .rating-outof {
      font-size: 20px;
      color: #666;
    }

    .rating-text {
      font-size: 18px;
      color: #333;
      margin-left: 10px;
    }

    .review-count {
      margin-top: 8px;
      font-size: 14px;
      color: #666;
    }

    /* RIGHT */
    .reviews-right {
      display: flex;
      flex-direction: column;
      align-items: center;
      padding-left: 30px;
    }

    .review-request {
      font-size: 16px;
      margin-bottom: 10px;
      margin-top:12px
      text-align: center;
    }

    .write-review-btn {
      padding: 12px 22px;
      border: none;
      background: #333;
      color: #eee;
      cursor: pointer;
      font-weight: 600;
      font-size: 15px;
    }

    .write-review-btn:hover {
      background: #000;
    }

    /* REVIEWS */
    .reviews-list {
      margin-top: 30px;
    }

    .review-item {
      padding: 20px 0;
      border-bottom: 1px solid #eee;
    }

    .review-user {
      display: flex;
      align-items: center;
      gap: 12px;
    }

    .avatar {
      width: 40px;
      height: 40px;
      border-radius: 50%;
      background: #f472b6;
      color: white;
      display: flex;
      align-items: center;
      justify-content: center;
      font-weight: bold;
    }

    .name {
      font-weight: 600;
    }

    .verified {
      font-size: 12px;
      color: #16a34a;
    }

    .review-stars {
      color: #333333;
      margin: 10px 0 6px;
      font-size: 16px;
    }

    .review-text {
      color: #333;
      font-size: 14px;
      line-height: 1.5;
    }

  </style>

  <script>
  (function() {
    // ═══════════════════════════════════════════════════════════
    // CONFIGURATION
    // ═══════════════════════════════════════════════════════════
    const REVIEW_API_BASE = 'https://reviews-system.onrender.com';

    // Book code is stored as a product tag (e.g. T210, B7)
    const ALL_TAGS = {{ product.tags | json }};
    const BOOK_CODE = ALL_TAGS.find(t => /^[A-Za-z]+\d+$/.test(t)) || '{{ product.handle }}';

    // Customer info from Shopify (empty string if not logged in)
    const CUSTOMER_EMAIL = '{{ customer.email | default: "" }}';

    // SVG star markup for full and half
    function getStarSVG(fill = 1) {
      if (fill === 1) {
        return `<svg viewBox="0 0 24 24"><polygon fill="#fbbf24" stroke="#fbbf24" stroke-width="1" points="12,2 15,9 22,9.5 17,14.5 18.5,22 12,18 5.5,22 7,14.5 2,9.5 9,9"/></svg>`;
      } else if (fill === 0.5) {
        return `<svg viewBox="0 0 24 24"><defs><linearGradient id="half"><stop offset="50%" stop-color="#fbbf24"/><stop offset="50%" stop-color="#bbb"/></linearGradient></defs><polygon fill="url(#half)" stroke="#fbbf24" stroke-width="1" points="12,2 15,9 22,9.5 17,14.5 18.5,22 12,18 5.5,22 7,14.5 2,9.5 9,9"/></svg>`;
      } else {
        return `<svg viewBox="0 0 24 24"><polygon fill="#bbb" stroke="#bbb" stroke-width="1" points="12,2 15,9 22,9.5 17,14.5 18.5,22 12,18 5.5,22 7,14.5 2,9.5 9,9"/></svg>`;
      }
    }

    function getStarString(rating) {
      let s = '';
      for (let i = 1; i <= 5; i++) {
        if (rating >= i) s += '★';
        else if (rating >= i - 0.5) s += '★'; // half shown as full in text
        else s += '☆';
      }
      return s;
    }

    // Interactive stars logic (main widget)
    const stars = document.querySelectorAll('#interactive-stars .star-svg');
    const modal = document.getElementById('review-modal');
    const closeModal = document.getElementById('close-modal');
    const modalStars = document.getElementById('modal-stars');
    let selectedRating = 0;
    let hoverRating = 0;

    function renderStars(rating) {
      stars.forEach((star, i) => {
        let fill = 0;
        if (rating >= i + 1) fill = 1;
        else if (rating >= i + 0.5) fill = 0.5;
        star.innerHTML = getStarSVG(fill);
      });
    }

    stars.forEach((star, idx) => {
      star.addEventListener('mousemove', (e) => {
        const rect = star.getBoundingClientRect();
        const x = e.clientX - rect.left;
        const half = x < rect.width / 2 ? 0.5 : 1;
        hoverRating = idx + half;
        renderStars(hoverRating);
      });
      star.addEventListener('mouseleave', () => {
        hoverRating = 0;
        renderStars(selectedRating);
      });
      star.addEventListener('click', (e) => {
        const rect = star.getBoundingClientRect();
        const x = e.clientX - rect.left;
        const half = x < rect.width / 2 ? 0.5 : 1;
        selectedRating = idx + half;
        renderStars(selectedRating);
        showModal(selectedRating);
      });
    });
    renderStars(selectedRating);

    // Hide interactive stars if not logged in
    if (!CUSTOMER_EMAIL) {
      document.querySelector('.review-request').textContent = 'Log in to share your experience!';
      document.getElementById('interactive-stars').style.display = 'none';
    }

    // ── Modal logic ───────────────────────────────────────────
    function showModal(rating) {
      modal.style.display = 'flex';
      renderModalStars(rating);
    }
    function hideModal() {
      modal.style.display = 'none';
      document.getElementById('review-textarea').value = '';
    }
    closeModal.addEventListener('click', hideModal);
    window.addEventListener('click', function(e) {
      if (e.target === modal) hideModal();
    });

    function renderModalStars(rating) {
      modalStars.innerHTML = '';
      for (let i = 1; i <= 5; i++) {
        let fill = 0;
        if (rating >= i) fill = 1;
        else if (rating >= i - 0.5) fill = 0.5;
        const s = document.createElement('span');
        s.className = 'star-svg';
        s.innerHTML = getStarSVG(fill);
        s.setAttribute('data-value', i);
        s.style.cursor = 'pointer';
        s.addEventListener('mousemove', (e) => {
          const rect = s.getBoundingClientRect();
          const x = e.clientX - rect.left;
          const half = x < rect.width / 2 ? 0.5 : 1;
          renderModalStars(i - 1 + half);
        });
        s.addEventListener('mouseleave', () => {
          renderModalStars(selectedRating);
        });
        s.addEventListener('click', (e) => {
          const rect = s.getBoundingClientRect();
          const x = e.clientX - rect.left;
          const half = x < rect.width / 2 ? 0.5 : 1;
          selectedRating = i - 1 + half;
          renderModalStars(selectedRating);
        });
        modalStars.appendChild(s);
      }
    }

    // ── Submit review ─────────────────────────────────────────
    document.querySelector('.submit-review-btn').addEventListener('click', async function() {
      const reviewText = document.getElementById('review-textarea').value.trim();

      if (!selectedRating) {
        alert('Please select a rating.');
        return;
      }

      if (!CUSTOMER_EMAIL) {
        alert('Please log in to submit a review.');
        return;
      }

      const btn = this;
      btn.disabled = true;
      btn.textContent = 'Submitting…';

      try {
        const res = await fetch(REVIEW_API_BASE + '/reviews', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({
            book_code: BOOK_CODE,
            customer_email: CUSTOMER_EMAIL,
            rating: selectedRating,
            review_text: reviewText || null,
          }),
        });

        const data = await res.json();

        if (res.ok) {
          alert('Thank you for your review!');
          hideModal();
          selectedRating = 0;
          renderStars(0);
          loadReviews(); // refresh list
        } else {
          alert(data.detail || 'Could not submit review. Please try again.');
        }
      } catch (err) {
        alert('Network error. Please try again later.');
      } finally {
        btn.disabled = false;
        btn.textContent = 'Submit';
      }
    });

    // ── Load reviews from API ─────────────────────────────────
    async function loadReviews() {
      const listEl = document.getElementById('reviews-list');
      const avgEl = document.getElementById('avg-rating');
      const countEl = document.getElementById('review-count');

      try {
        const res = await fetch(
          REVIEW_API_BASE + '/reviews?book_code=' + encodeURIComponent(BOOK_CODE)
        );
        const data = await res.json();

        avgEl.textContent = data.average_rating || '—';
        countEl.textContent = data.total_reviews
          ? data.total_reviews + ' verified rating' + (data.total_reviews !== 1 ? 's' : '')
          : 'No reviews yet';

        if (!data.reviews || data.reviews.length === 0) {
          listEl.innerHTML = '<p style="color:#888;padding:20px 0;">Be the first to review this book!</p>';
          return;
        }

        listEl.innerHTML = data.reviews.map(function(r) {
          const initial = (r.customer_email || '?')[0].toUpperCase();
          const name = r.customer_email.split('@')[0];
          const verifiedBadge = r.verified
            ? '<div class="verified">✔ Verified Reader</div>'
            : '';
          return `
            <div class="review-item">
              <div class="review-user">
                <div class="avatar">${initial}</div>
                <div>
                  <div class="name">${name}</div>
                  ${verifiedBadge}
                </div>
              </div>
              <div class="review-stars">${getStarString(r.rating)}</div>
              <div class="review-text">${r.review_text ? '"' + r.review_text.replace(/</g, '&lt;').replace(/>/g, '&gt;') + '"' : ''}</div>
            </div>`;
        }).join('');
      } catch (err) {
        listEl.innerHTML = '<p style="color:#888;padding:20px 0;">Could not load reviews.</p>';
      }
    }

    // Load reviews on page load
    loadReviews();
  })();
  </script>

</div>